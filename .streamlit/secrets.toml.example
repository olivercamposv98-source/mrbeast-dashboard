# Copia este archivo como "secrets.toml" (local) o pégalo en
# Streamlit Cloud -> App -> Settings -> Secrets.
# NUNCA subas secrets.toml a GitHub (ya está en .gitignore).

# ── OPCIÓN A: Hoja pública (la más simple) ─────────────────────────────
# En Google Sheets: Compartir -> "Cualquier persona con el enlace" -> Lector
[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/TU_ID_DE_HOJA/edit"
worksheet = "0"   # gid de la pestaña (0 = primera)

# ── OPCIÓN B: Hoja privada con Service Account ─────────────────────────
# 1. console.cloud.google.com -> crear proyecto -> habilitar "Google Sheets API" y "Google Drive API"
# 2. Crear Service Account -> Keys -> JSON -> copiar los campos aquí
# 3. Compartir la hoja con el email del service account (Lector)
#
# [connections.gsheets]
# spreadsheet = "https://docs.google.com/spreadsheets/d/TU_ID_DE_HOJA/edit"
# worksheet = "0"
# type = "service_account"
# project_id = "tu-proyecto"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "cuenta@tu-proyecto.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
